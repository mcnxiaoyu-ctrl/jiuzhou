# 数据库配置
DB_HOST=localhost
DB_PORT=5432
DB_NAME=jiuzhou
DB_USER=postgres
DB_PASSWORD=your-db-password
DB_LOG=false

# Redis配置
REDIS_URL="redis://localhost:6379"

# JWT配置
JWT_SECRET="your-super-secret-jwt-key"
JWT_EXPIRES_IN="7d"

# 服务器配置
HOST=0.0.0.0
PORT=6011
NODE_ENV=development

# 跨域配置
CORS_ORIGIN="http://localhost:6010"

# 启动与系统配置
# 未配置时默认使用 CPU 核数 - 1（最少 1）
IDLE_WORKER_COUNT=1
# 游戏内时间流速倍率（默认 60）
GAME_TIME_SCALE=60

# 角色体力恢复配置
STAMINA_MAX=100
STAMINA_RECOVER_PER_TICK=1
STAMINA_RECOVER_INTERVAL_SEC=300

# 境界配置文件路径（可选；不填则按内置路径顺序查找）
REALM_CONFIG_PATH=""

# 一次性脚本开关（仅在需要清空头像时设为 1）
# CLEAR_AVATARS=1

# 腾讯云 COS 配置（头像上传）
# 未配置时自动回退本地磁盘存储
COS_SECRET_ID=""
COS_SECRET_KEY=""
COS_BUCKET=""
COS_REGION="ap-guangzhou"
COS_AVATAR_PREFIX="avatars/"
# 自定义域名（不含协议和末尾 /），例如 oss.example.com
# 配置后头像 URL 会使用此域名，未配置则使用 COS 默认域名
COS_DOMAIN=""
