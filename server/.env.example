# 数据库配置
DB_HOST=localhost
DB_PORT=6060
DB_NAME=jiuzshou_s
DB_USER=postgres
DB_PASSWORD=your-db-password
DB_LOG=false

# Redis配置
REDIS_URL="redis://localhost:6379"

# JWT配置
JWT_SECRET="your-super-secret-jwt-key"
JWT_EXPIRES_IN="7d"

# 服务器配置
PORT=6011
NODE_ENV=development

# 跨域配置
CORS_ORIGIN="http://localhost:6010"

# 火山方舟图片生成脚本配置
ARK_API_KEY="your-ark-api-key"

# 本地 RMBG 抠图配置（ModelScope）
# 首次执行会自动下载模型，默认模型 ID：AI-ModelScope/RMBG-2.0
RMBG_MODELSCOPE_MODEL_ID="AI-ModelScope/RMBG-2.0"
# 模型缓存目录（支持相对路径，默认 server/.cache/modelscope）
RMBG_MODELSCOPE_CACHE_DIR=".cache/modelscope"
# 推理设备：auto / cpu / cuda（默认 auto）
RMBG_DEVICE="auto"
