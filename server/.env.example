# 数据库配置
DB_HOST=localhost
DB_PORT=5432
DB_NAME=jiuzhou
DB_USER=postgres
DB_PASSWORD=your-db-password
DB_LOG=false
DATABASE_URL="postgresql://postgres:your-db-password@localhost:5432/jiuzhou"
DB_POOL_MAX=600
DB_POOL_MIN=20
DB_POOL_IDLE_TIMEOUT_MS=30000
DB_POOL_CONNECT_TIMEOUT_MS=5000
DB_POOL_KEEPALIVE_DELAY_MS=10000
DB_POOL_MAX_USES=7500
DB_POOL_MAX_LIFETIME_SECONDS=900
DB_APPLICATION_NAME=jiuzhou-server

# Redis配置
REDIS_URL="redis://localhost:6379"

# JWT配置
JWT_SECRET="your-super-secret-jwt-key"
JWT_EXPIRES_IN="7d"

# 服务器配置
HOST=0.0.0.0
PORT=6011
NODE_ENV=development

# 跨域配置
CORS_ORIGIN="http://localhost:6010"

# 爱发电 OpenAPI / Webhook
AFDIAN_OPEN_USER_ID=
AFDIAN_OPEN_TOKEN=
# 默认使用官方 ifdian.net OpenAPI 域名
AFDIAN_OPEN_API_BASE_URL=https://ifdian.net
AFDIAN_MESSAGE_RETRY_ENABLED=true
AFDIAN_MESSAGE_RETRY_INTERVAL_SECONDS=60
AFDIAN_MESSAGE_RETRY_BATCH_SIZE=10

# 启动与系统配置
# 未配置时默认使用 CPU 核数 - 1（最少 1）
IDLE_WORKER_COUNT=1
# AI 伙伴招募 worker 池并发数（默认 10）
PARTNER_RECRUIT_WORKER_COUNT=10
# 洞府研修 worker 池并发数（默认 10）
TECHNIQUE_GENERATION_WORKER_COUNT=10
# 云游奇遇 worker 池并发数（默认 10）
WANDER_WORKER_COUNT=10
# 挂机会话历史定时清理：是否启用（默认 true）
IDLE_HISTORY_CLEANUP_ENABLED=true
# 每个角色保留的已结束挂机会话数（默认 3）
IDLE_HISTORY_KEEP_COUNT=3
# 定时清理执行间隔（秒，默认 600）
IDLE_HISTORY_CLEANUP_INTERVAL_SECONDS=600
# 单批删除的历史会话数（默认 20，删除会级联清理其下所有战斗批次）
IDLE_HISTORY_CLEANUP_DELETE_SESSION_BATCH_SIZE=20
# 单轮最多删除批次数（默认 20）
IDLE_HISTORY_CLEANUP_MAX_BATCHES_PER_RUN=20
# 游戏内时间流速倍率（默认 60）
GAME_TIME_SCALE=60

# 角色体力恢复配置
STAMINA_MAX=100
STAMINA_RECOVER_PER_TICK=1
STAMINA_RECOVER_INTERVAL_SEC=300

# 境界配置文件路径（可选；不填则按内置路径顺序查找）
REALM_CONFIG_PATH=""

# 一次性脚本开关（仅在需要清空头像时设为 1）
# CLEAR_AVATARS=1

# 腾讯云 COS 配置（头像上传）
# 未配置时自动回退本地磁盘存储
# 固定密钥仅在服务端用于签发头像上传 STS 与删除旧头像，不会直接下发前端
COS_SECRET_ID=""
COS_SECRET_KEY=""
COS_BUCKET=""
COS_REGION="ap-guangzhou"
COS_AVATAR_PREFIX="avatars/"
# AI 生成图片对象前缀（伙伴头像、技能图标）
COS_GENERATED_IMAGE_PREFIX="generated/"
# 自定义域名（不含协议和末尾 /），例如 oss.example.com
# 配置后头像 URL 会使用此域名，未配置则使用 COS 默认域名
COS_DOMAIN=""
# 头像上传 STS 有效期（秒，默认 600，最大 7200）
COS_STS_DURATION_SECONDS=600

# 功法 AI 文本模型
# OpenAI SDK 会读取这里作为 baseURL；可填基础地址（如 https://api.openai.com）
# 若你填了完整地址（.../v1 或 .../v1/chat/completions），服务也会自动归一化为 SDK baseURL
# provider:
# - openai（默认）: 走 OpenAI 兼容接口
# - anthropic: 走 Anthropic 官方 API（不支持 response_format / seed，由 prompt 约束 JSON 格式）
#   Anthropic 可不填 MODEL_URL，SDK 默认使用 https://api.anthropic.com；如需自定义可填写
AI_TECHNIQUE_MODEL_PROVIDER=openai
AI_TECHNIQUE_MODEL_URL=
AI_TECHNIQUE_MODEL_KEY=
AI_TECHNIQUE_MODEL_NAME=

# 伙伴 AI 文本模型
# 配置规则与功法文本模型一致，但两者完全独立，互不共用环境变量
AI_PARTNER_MODEL_PROVIDER=openai
AI_PARTNER_MODEL_URL=
AI_PARTNER_MODEL_KEY=
AI_PARTNER_MODEL_NAME=

# 云游 AI 文本模型
# 配置规则与功法/伙伴文本模型一致，但云游奇遇单独读取这一组环境变量
# 智谱标准 API 可按 OpenAI 兼容方式接入，例如：
# - AI_WANDER_MODEL_PROVIDER=openai
# - AI_WANDER_MODEL_URL=https://open.bigmodel.cn/api/paas/v4/chat/completions
# - AI_WANDER_MODEL_NAME=glm-4.7
AI_WANDER_MODEL_PROVIDER=openai
AI_WANDER_MODEL_URL=
AI_WANDER_MODEL_KEY=
AI_WANDER_MODEL_NAME=

# 敏感词检测服务配置
# 开启后，聊天消息、角色道号、功法自定义名称会共用该检测入口
SENSITIVE_WORD_SERVICE_ENABLED=false
# 只填写服务基础地址，例如 http://192.168.99.110:8080
SENSITIVE_WORD_SERVICE_BASE_URL=
# 请求超时（毫秒）
SENSITIVE_WORD_SERVICE_TIMEOUT_MS=3000

# AI 图片生成（功法技能图标与伙伴头像共用；可选；不配置则自动回退默认资源）
# provider:
# - auto: 自动识别（模型名是 qwen-image-* 或 URL 含 dashscope 时走千问专用接口）
# - dashscope: 强制走千问专用文生图接口
# - openai: 强制走 OpenAI 兼容接口
AI_TECHNIQUE_IMAGE_PROVIDER=auto
# 千问推荐填基础地址（服务会自动补全为 /api/v1/services/aigc/multimodal-generation/generation）：
# AI_TECHNIQUE_IMAGE_MODEL_URL=https://dashscope.aliyuncs.com
# OpenAI SDK 可填基础地址（如 https://api.openai.com）或完整地址（.../v1 / .../v1/images/generations）
AI_TECHNIQUE_IMAGE_MODEL_URL=
AI_TECHNIQUE_IMAGE_MODEL_KEY=
AI_TECHNIQUE_IMAGE_MODEL_NAME=qwen-image-2.0
AI_TECHNIQUE_IMAGE_SIZE=512x512
# 默认 b64_json
AI_TECHNIQUE_IMAGE_RESPONSE_FORMAT=b64_json
AI_TECHNIQUE_IMAGE_TIMEOUT_MS=15000
# 单次最多为多少个技能生成图片（建议 <= 4）
AI_TECHNIQUE_IMAGE_MAX_SKILLS=4
# 是否打印图片生成调试日志（true/false）
AI_TECHNIQUE_IMAGE_DEBUG=false

# 坊市手机号绑定（默认关闭；只有显式开启并补齐短信配置后才生效）
MARKET_PHONE_BINDING_ENABLED=false
# 验证码有效期（秒）
MARKET_PHONE_BINDING_CODE_EXPIRE_SECONDS=300
# 发送验证码冷却（秒）
MARKET_PHONE_BINDING_SEND_COOLDOWN_SECONDS=60
# 发送验证码限次（按账号维度、Asia/Shanghai 自然小时/自然日）
MARKET_PHONE_BINDING_SEND_HOURLY_LIMIT=5
MARKET_PHONE_BINDING_SEND_DAILY_LIMIT=10
# 阿里云短信签名与验证码模板编码
# 验证码模板里的验证码变量必须写成 ##code##，这样阿里云才能继续核验用户输入的验证码
ALIYUN_SMS_SIGN_NAME=
ALIYUN_SMS_VERIFY_TEMPLATE_CODE=
# 阿里云凭据建议使用官方默认凭据链，例如环境变量：
# ALIBABA_CLOUD_ACCESS_KEY_ID=
# ALIBABA_CLOUD_ACCESS_KEY_SECRET=

# 验证码提供方配置
# 可选值：local（默认，服务端图片验证码）、tencent（腾讯云天御验证码）
CAPTCHA_PROVIDER=local
# 以下配置仅在 CAPTCHA_PROVIDER=tencent 时需要
# 腾讯云验证码控制台的 CaptchaAppId 和 AppSecretKey
TENCENT_CAPTCHA_APP_ID=
TENCENT_CAPTCHA_APP_SECRET_KEY=
# 腾讯云 API 密钥（用于 SDK 鉴权）
TENCENT_CAPTCHA_SECRET_ID=
TENCENT_CAPTCHA_SECRET_KEY=

# 坊市购买专用腾讯云验证码配置（仅购买按钮使用）
MARKET_PURCHASE_TENCENT_CAPTCHA_APP_ID=
MARKET_PURCHASE_TENCENT_CAPTCHA_APP_SECRET_KEY=
