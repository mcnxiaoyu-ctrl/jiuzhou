# 数据库配置
DB_HOST=localhost
DB_PORT=6060
DB_NAME=jiuzshou_s
DB_USER=postgres
DB_PASSWORD=your-db-password
DB_LOG=false

# Redis配置
REDIS_URL="redis://localhost:6379"

# JWT配置
JWT_SECRET="your-super-secret-jwt-key"
JWT_EXPIRES_IN="7d"

# 服务器配置
PORT=6011
NODE_ENV=development

# 跨域配置
CORS_ORIGIN="http://localhost:6010"

# 火山方舟图片生成脚本配置
ARK_API_KEY="your-ark-api-key"

# 腾讯云 COS 配置（头像上传）
# 未配置时自动回退本地磁盘存储
COS_SECRET_ID=""
COS_SECRET_KEY=""
COS_BUCKET=""
COS_REGION="ap-guangzhou"
COS_AVATAR_PREFIX="avatars/"
# 自定义域名（不含协议和末尾 /），例如 oss.example.com
# 配置后头像 URL 会使用此域名，未配置则使用 COS 默认域名
COS_DOMAIN=""

# 本地 RMBG 抠图配置（ModelScope）
# 首次执行会自动下载模型，默认模型 ID：AI-ModelScope/RMBG-2.0
RMBG_MODELSCOPE_MODEL_ID="AI-ModelScope/RMBG-2.0"
# 模型缓存目录（支持相对路径，默认 server/.cache/modelscope）
RMBG_MODELSCOPE_CACHE_DIR=".cache/modelscope"
# 推理设备：auto / cpu / cuda（默认 auto）
RMBG_DEVICE="auto"
